<?xml version="1.0" encoding="UTF-8"?>
<EnforcedFunction Name="TradingEnforcer">
	<Interface>
		<Input Name="dd_exceeded" Type="bool" Constant="false" Comment=""></Input>
		<Input Name="is_illiquid" Type="bool" Constant="false" Comment=""></Input>
		<Input Name="will_exceed_limit" Type="bool" Constant="false" Comment=""></Input>
		<Input Name="price_deviates" Type="bool" Constant="false" Comment=""></Input>
		<Input Name="act_EXEC" Type="bool" Constant="false" Comment=""></Input>
		<Output Name="act_PLACE" Type="bool" Constant="false" Comment=""></Output>
		<Output Name="act_BUY" Type="bool" Constant="false" Comment=""></Output>
		<Output Name="act_MSG" Type="bool" Constant="false" Comment=""></Output>
		<Output Name="act_CANCEL" Type="bool" Constant="false" Comment=""></Output>
		<Output Name="act_SELL" Type="bool" Constant="false" Comment=""></Output>
		<Output Name="price" Type="int32_t" Constant="false" Comment=""></Output>
	</Interface>
	<Policy Name="RateLimit_5_per_1s">
		<InternalVars>
			<VarDeclaration Name="t_window" Type="dtimer_t" Constant="false" Comment=""></VarDeclaration>
			<VarDeclaration Name="T_WINDOW" Type="uint64_t" Constant="true" InitialValue="5" Comment=""></VarDeclaration>
		</InternalVars>
		<Machine>
			<PState>s0</PState>
			<PState>s1</PState>
			<PState>s2</PState>
			<PState>s3</PState>
			<PState>s4</PState>
			<PState>s5</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s2</Destination>
				<Condition>( act_PLACE and t_window &lt; T_WINDOW )</Condition>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE and t_window &gt;= T_WINDOW )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s1</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s3</Destination>
				<Condition>( act_PLACE and t_window &lt; T_WINDOW )</Condition>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE and t_window &gt;= T_WINDOW )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s2</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s3</Source>
				<Destination>s4</Destination>
				<Condition>( act_PLACE and t_window &lt; T_WINDOW )</Condition>
			</PTransition>
			<PTransition>
				<Source>s3</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE and t_window &gt;= T_WINDOW )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s3</Source>
				<Destination>s3</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s4</Source>
				<Destination>s5</Destination>
				<Condition>( act_PLACE and t_window &lt; T_WINDOW )</Condition>
			</PTransition>
			<PTransition>
				<Source>s4</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE and t_window &gt;= T_WINDOW )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s4</Source>
				<Destination>s4</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s5</Source>
				<Destination>s1</Destination>
				<Condition>( act_PLACE and t_window &gt;= T_WINDOW )</Condition>
				<Expressions>
					<VarName>t_window</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s5</Source>
				<Destination>s5</Destination>
				<Condition>( !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s5</Source>
				<Destination>violation</Destination>
				<Condition>( act_PLACE and t_window &lt; T_WINDOW )</Condition>
				<Recover>
					<VarName>act_PLACE</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="LatchingKillSwitch">
		<InternalVars></InternalVars>
		<Machine>
			<PState>s0</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( dd_exceeded and !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !dd_exceeded )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>violation</Destination>
				<Condition>( dd_exceeded and act_PLACE )</Condition>
				<Recover>
					<VarName>act_PLACE</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="RejectDeviantPrice">
		<InternalVars></InternalVars>
		<Machine>
			<PState>s0</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( price_deviates and !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !price_deviates )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>violation</Destination>
				<Condition>( price_deviates and act_PLACE )</Condition>
				<Recover>
					<VarName>act_PLACE</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="BlockConcentratedBuy">
		<InternalVars></InternalVars>
		<Machine>
			<PState>s0</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( will_exceed_limit and !act_BUY )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !will_exceed_limit )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>violation</Destination>
				<Condition>( will_exceed_limit and act_BUY )</Condition>
				<Recover>
					<VarName>act_BUY</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="BlockIlliquidTrade">
		<InternalVars></InternalVars>
		<Machine>
			<PState>s0</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( is_illiquid and !act_PLACE )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !is_illiquid )</Condition>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>violation</Destination>
				<Condition>( is_illiquid and act_PLACE )</Condition>
				<Recover>
					<VarName>act_PLACE</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="OTR_Policy">
		<InternalVars>
			<VarDeclaration Name="tokens" Type="int32_t" Constant="false" InitialValue="500" Comment=""></VarDeclaration>
			<VarDeclaration Name="Max_Cap" Type="int32_t" Constant="true" InitialValue="500" Comment=""></VarDeclaration>
			<VarDeclaration Name="Reward" Type="int32_t" Constant="true" InitialValue="50" Comment=""></VarDeclaration>
			<VarDeclaration Name="Cost" Type="int32_t" Constant="true" InitialValue="1" Comment=""></VarDeclaration>
			<VarDeclaration Name="Resume_Threshold" Type="int32_t" Constant="true" InitialValue="10" Comment=""></VarDeclaration>
		</InternalVars>
		<Machine>
			<PState>s_normal</PState>
			<PState>s_throttled</PState>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>act_EXEC and !act_MSG and ( tokens + Reward &lt;= Max_Cap )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens + Reward</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>act_EXEC and !act_MSG and ( tokens + Reward &gt; Max_Cap )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>Max_Cap</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>act_EXEC and act_MSG and ( tokens + Reward - Cost &lt;= Max_Cap )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens + Reward - Cost</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>act_EXEC and act_MSG and ( tokens + Reward - Cost &gt; Max_Cap )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>Max_Cap</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>!act_EXEC and act_MSG and ( tokens - Cost &gt; 0 )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens - Cost</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_throttled</Destination>
				<Condition>!act_EXEC and act_MSG and ( tokens - Cost &lt;= 0 )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens - Cost</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_normal</Source>
				<Destination>s_normal</Destination>
				<Condition>!act_EXEC and !act_MSG</Condition>
			</PTransition>
			<PTransition>
				<Source>s_throttled</Source>
				<Destination>s_throttled</Destination>
				<Condition>act_EXEC and ( tokens + Reward &lt;= Resume_Threshold )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens + Reward</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_throttled</Source>
				<Destination>s_normal</Destination>
				<Condition>act_EXEC and ( tokens + Reward &gt; Resume_Threshold )</Condition>
				<Expressions>
					<VarName>tokens</VarName>
					<Value>tokens + Reward</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s_throttled</Source>
				<Destination>s_throttled</Destination>
				<Condition>!act_EXEC</Condition>
			</PTransition>
			<PTransition>
				<Source>s_throttled</Source>
				<Destination>violation</Destination>
				<Condition>act_MSG</Condition>
				<Recover>
					<VarName>act_MSG</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="MQL_Policy">
		<InternalVars>
			<VarDeclaration Name="c_age" Type="dtimer_t" Constant="false" Comment=""></VarDeclaration>
			<VarDeclaration Name="T_MQL" Type="int64_t" Constant="true" InitialValue="100" Comment=""></VarDeclaration>
		</InternalVars>
		<Machine>
			<PState>empty</PState>
			<PState>resting</PState>
			<PTransition>
				<Source>empty</Source>
				<Destination>resting</Destination>
				<Condition>act_PLACE</Condition>
				<Expressions>
					<VarName>c_age</VarName>
					<Value>0</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>empty</Source>
				<Destination>empty</Destination>
				<Condition>!act_PLACE</Condition>
			</PTransition>
			<PTransition>
				<Source>resting</Source>
				<Destination>empty</Destination>
				<Condition>act_CANCEL and c_age &gt;= T_MQL</Condition>
			</PTransition>
			<PTransition>
				<Source>resting</Source>
				<Destination>resting</Destination>
				<Condition>!act_CANCEL</Condition>
			</PTransition>
			<PTransition>
				<Source>resting</Source>
				<Destination>violation</Destination>
				<Condition>act_CANCEL and c_age &lt; T_MQL</Condition>
				<Recover>
					<VarName>act_CANCEL</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
	<Policy Name="NoWash">
		<InternalVars>
			<VarDeclaration Name="last_bid" Type="int32_t" Constant="false" InitialValue="0" Comment=""></VarDeclaration>
			<VarDeclaration Name="last_ask" Type="int32_t" Constant="false" InitialValue="4000000000" Comment=""></VarDeclaration>
		</InternalVars>
		<Machine>
			<PState>s0</PState>
			<PState>s1</PState>
			<PState>s2</PState>
			<PTransition>
				<Source>s0</Source>
				<Destination>s1</Destination>
				<Condition>act_BUY</Condition>
				<Expressions>
					<VarName>last_bid</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s2</Destination>
				<Condition>act_SELL</Condition>
				<Expressions>
					<VarName>last_ask</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s0</Source>
				<Destination>s0</Destination>
				<Condition>( !act_BUY and !act_SELL )</Condition>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s1</Destination>
				<Condition>act_BUY</Condition>
				<Expressions>
					<VarName>last_bid</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s2</Destination>
				<Condition>( act_SELL and price &gt; last_bid )</Condition>
				<Expressions>
					<VarName>last_ask</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>s1</Destination>
				<Condition>( !act_BUY and !act_SELL )</Condition>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s2</Destination>
				<Condition>act_SELL</Condition>
				<Expressions>
					<VarName>last_ask</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s1</Destination>
				<Condition>( act_BUY and price &lt; last_ask )</Condition>
				<Expressions>
					<VarName>last_bid</VarName>
					<Value>price</Value>
				</Expressions>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>s2</Destination>
				<Condition>( !act_BUY and !act_SELL )</Condition>
			</PTransition>
			<PTransition>
				<Source>s1</Source>
				<Destination>violation</Destination>
				<Condition>( act_SELL and price &lt;= last_bid )</Condition>
				<Recover>
					<VarName>act_SELL</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
			<PTransition>
				<Source>s2</Source>
				<Destination>violation</Destination>
				<Condition>( act_BUY and price &gt;= last_ask )</Condition>
				<Recover>
					<VarName>act_BUY</VarName>
					<Value>0</Value>
				</Recover>
			</PTransition>
		</Machine>
	</Policy>
</EnforcedFunction>